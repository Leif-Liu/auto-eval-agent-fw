# Agent Evaluation Framework - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (required for LLM-as-a-Judge)
OPENAI_API_KEY=sk-your-api-key-here

# Agent API endpoint
AGENT_BASE_URL=http://localhost:8080

# Optional: override OpenAI model (default: gpt-4o)
OPENAI_MODEL=gpt-4o
