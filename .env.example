# Agent Evaluation Framework - Environment Variables
# Copy this file to .env and fill in your values

# LLM Judge (vLLM / OpenAI-compatible) configuration
OPENAI_API_KEY=vllm
OPENAI_BASE_URL=http://10.10.11.7:11542/v1
OPENAI_MODEL=google/gemma-4-31B-it

# RAGFlow Agent configuration
RAGFLOW_API_KEY=your-ragflow-api-key
RAGFLOW_AGENT_ID=your-agent-id
RAGFLOW_BASE_URL=http://10.10.11.7:9380

# Dataset flywheel tooling (optional, defaults shown)
# DATASET_STAGING_DIR=./test_data/_staging
# DATASET_BACKUP_DIR=./test_data/_backups
# DATASET_CHANGELOG_PATH=./CHANGELOG.md
# DATASET_DEFAULT_VERSION=0.1.0
# DATASET_DEDUP_THRESHOLD=0.85

# Evolution dashboard / monitoring agent (optional, defaults shown)
# MONITORING_REGRESSION_THRESHOLD=-3.0   # total-score delta vs prev run flagged red
# MONITORING_SLOPE_MIN_RUNS=3            # min runs before per-dimension slope is computed
