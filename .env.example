# Agent Evaluation Framework - Environment Variables
# Copy this file to .env and fill in your values

# LLM Judge (vLLM / OpenAI-compatible) configuration
OPENAI_API_KEY=vllm
OPENAI_BASE_URL=http://10.10.11.7:11542/v1
OPENAI_MODEL=google/gemma-4-31B-it

# RAGFlow Agent configuration
RAGFLOW_API_KEY=your-ragflow-api-key
RAGFLOW_AGENT_ID=your-agent-id
RAGFLOW_BASE_URL=http://10.10.11.7:9380

# Claude Agent SDK configuration (for code-reader agent)
ANTHROPIC_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/apps/anthropic
ANTHROPIC_AUTH_TOKEN=sk-...xxx
ANTHROPIC_MODEL=claude-opus-4-7
